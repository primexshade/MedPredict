# ═══════════════════════════════════════════════════════════════════════════════
# MedPredict .gitignore
# ═══════════════════════════════════════════════════════════════════════════════

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# ── Virtual Environments ──────────────────────────────────────────────────────
.venv/
venv/
ENV/
env/
.conda/

# ── IDE / Editor ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~
.project
.pydevproject
.settings/
*.sublime-project
*.sublime-workspace

# ── OS Files ──────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
*.bak

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
.hypothesis/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.local
.env.*.local
*.pem
*.key
secrets.yaml
secrets.json

# ── Database ──────────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
medpredict.db

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
log/

# ── MLflow / Models ───────────────────────────────────────────────────────────
mlruns/
mlartifacts/
models/*.pkl
models/*.joblib
models/*.h5
models/*.pt
models/*.onnx
!models/.gitkeep

# ── Jupyter Notebooks ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints
notebooks/*.ipynb
!notebooks/.gitkeep

# ── Node.js / Frontend ────────────────────────────────────────────────────────
node_modules/
frontend/node_modules/
frontend/dist/
frontend/.cache/
.npm/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# ── Build Artifacts ───────────────────────────────────────────────────────────
*.manifest
*.spec
dist/
*.whl

# ── Docker ────────────────────────────────────────────────────────────────────
docker/*.env

# ── Temporary Files ───────────────────────────────────────────────────────────
tmp/
temp/
*.tmp
*.temp
*.bak
*.swp

# ── Data Files (keep structure, ignore large data) ───────────────────────────
data/raw/*.csv
data/raw/*.parquet
data/processed/*.csv
data/processed/*.parquet
!data/raw/.gitkeep
!data/processed/.gitkeep

# ── Alembic ───────────────────────────────────────────────────────────────────
alembic/versions/*.pyc

# ── mypy ──────────────────────────────────────────────────────────────────────
.mypy_cache/
.dmypy.json
dmypy.json

# ── Ruff ──────────────────────────────────────────────────────────────────────
.ruff_cache/
